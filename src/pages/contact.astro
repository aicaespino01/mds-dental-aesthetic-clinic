---
import Layout from '../layouts/Layout.astro';
import PageIntro from '../components/PageIntro.astro';

const services = [
  'General checkup & cleaning',
  'Orthodontic consultation',
  'TMJ evaluation',
  'Sleep & airway consultation',
  'Myofunctional therapy',
  'Invisalign / SmarTee consultation',
  'Oral surgery',
  'Aesthetic dentistry',
  "I'm not sure yet",
];
---

<Layout
  title="Contact"
  description="Book an appointment, call, or message MDS Dental & Aesthetic Clinic in Pulong Niogan, Mabini, Batangas."
>
  <PageIntro
    eyebrow="Get in touch"
    heading="Let's find a time that works."
    body="Call, message us on Facebook, or fill out the form below and we'll confirm your appointment directly."
  />

  <section class="contact-section">
    <div class="container contact-grid">
      <aside class="contact-info">
        <div class="info-block">
          <h2>Visit</h2>
          <p>Brgy. Pulong Niogan, Mabini,<br />Batangas, Philippines</p>
          <a href="https://maps.google.com/?q=Pulong+Niogan,+Mabini,+Batangas,+Philippines" target="_blank" rel="noopener noreferrer" class="info-link">
            Get directions &rarr;
          </a>
        </div>

        <div class="info-block">
          <h2>Call or message</h2>
          <p><a href="tel:+639541439492">+63 954 143 9492</a></p>
          <a href="https://m.me/mdsDental.docrhejz" target="_blank" rel="noopener noreferrer" class="info-link">
            Message us on Facebook &rarr;
          </a>
        </div>

        <div class="info-block">
          <h2>Availability</h2>
          <p>We're open almost every day. Tell us when works for you and we'll confirm a slot.</p>
          <a href="#book" class="info-link">Book your schedule &rarr;</a>
        </div>

        <div class="info-map">
          <iframe
            title="Map showing Pulong Niogan, Mabini, Batangas"
            src="https://maps.google.com/maps?q=Pulong+Niogan,+Mabini,+Batangas,+Philippines&z=14&output=embed"
            loading="lazy"
            referrerpolicy="no-referrer-when-downgrade"
          ></iframe>
        </div>
      </aside>

      <div class="contact-form-wrap" id="book">
        <h2>Request an appointment</h2>
        <p class="form-intro">
          We'll get back to you within one business day to confirm a time. For anything
          urgent, please call the clinic directly.
        </p>

        <form id="booking-form" novalidate>
          <div class="field-row">
            <div class="field">
              <label for="name">Full name</label>
              <input type="text" id="name" name="name" autocomplete="name" required />
              <p class="error-text" data-error-for="name" hidden>
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" aria-hidden="true"><circle cx="12" cy="12" r="9" stroke="currentColor" stroke-width="2"/><path d="M12 8v5M12 16h.01" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>
                Please enter your name.
              </p>
            </div>
            <div class="field">
              <label for="phone">Phone number</label>
              <input type="tel" id="phone" name="phone" autocomplete="tel" placeholder="09XX XXX XXXX" required />
              <p class="error-text" data-error-for="phone" hidden>
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" aria-hidden="true"><circle cx="12" cy="12" r="9" stroke="currentColor" stroke-width="2"/><path d="M12 8v5M12 16h.01" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>
                We need a phone number to confirm your visit.
              </p>
            </div>
          </div>

          <div class="field-row">
            <div class="field">
              <label for="service">Service you're interested in</label>
              <select id="service" name="service" required>
                <option value="" disabled selected>Choose a service</option>
                {services.map((s) => <option value={s}>{s}</option>)}
              </select>
            </div>
            <div class="field">
              <label for="date">Preferred date</label>
              <input type="date" id="date" name="date" />
              <p class="hint">Optional &mdash; we'll confirm exact availability with you.</p>
            </div>
          </div>

          <fieldset class="field contact-method">
            <legend>Preferred way to hear back</legend>
            <div class="radio-row">
              <label><input type="radio" name="contact-method" value="phone" checked /> Phone call</label>
              <label><input type="radio" name="contact-method" value="messenger" /> Messenger</label>
              <label><input type="radio" name="contact-method" value="sms" /> Text message</label>
            </div>
          </fieldset>

          <div class="field">
            <label for="message">Anything we should know? <span class="hint-inline">(optional)</span></label>
            <textarea id="message" name="message" rows="4" placeholder="e.g. jaw pain on one side for the past month"></textarea>
          </div>

          <button type="submit" class="btn btn-primary form-submit">
            <span class="btn-label">Request an appointment</span>
          </button>

          <p class="form-status" role="status" aria-live="polite" data-status hidden></p>
        </form>
      </div>
    </div>
  </section>
</Layout>

<style>
  .contact-section { padding-block: var(--space-3xl); }

  .contact-grid {
    display: grid;
    grid-template-columns: 0.85fr 1.15fr;
    gap: var(--space-3xl);
    align-items: start;
  }

  .contact-info {
    display: flex;
    flex-direction: column;
    gap: var(--space-xl);
    position: sticky;
    top: calc(72px + var(--space-lg));
  }

  .info-block h2 {
    font-family: var(--font-body);
    font-size: var(--text-xs);
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--ink-faint);
    margin-bottom: var(--space-xs);
  }

  .info-block p { color: var(--ink-soft); margin-bottom: var(--space-2xs); }
  .info-block a[href^="tel"], .info-block a[href^="mailto"] { color: var(--ink); font-weight: 500; }

  .info-link {
    display: inline-block;
    margin-top: var(--space-2xs);
    color: var(--brand-600);
    font-weight: 600;
    font-size: var(--text-sm);
  }
  .info-link:hover { color: var(--brand-700); }

  .info-map {
    border-radius: var(--radius-md);
    overflow: hidden;
    box-shadow: var(--shadow-sm);
    aspect-ratio: 4 / 3;
  }
  .info-map iframe { width: 100%; height: 100%; border: 0; }

  .contact-form-wrap {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    padding: var(--space-xl);
  }

  .contact-form-wrap h2 { font-size: var(--text-h3); }
  .form-intro { margin-top: var(--space-xs); color: var(--ink-soft); }

  #booking-form {
    margin-top: var(--space-xl);
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
  }

  .field-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-md);
  }

  .contact-method { border: none; padding: 0; margin: 0; }
  .contact-method legend {
    font-size: var(--text-sm);
    font-weight: 600;
    color: var(--ink);
    padding: 0;
    margin-bottom: var(--space-2xs);
  }

  .radio-row {
    display: flex;
    gap: var(--space-md);
    flex-wrap: wrap;
  }

  .radio-row label {
    display: flex;
    align-items: center;
    gap: var(--space-3xs);
    font-size: var(--text-sm);
    color: var(--ink-soft);
  }

  .hint-inline { font-weight: 400; color: var(--ink-faint); }

  .form-submit {
    justify-content: center;
    margin-top: var(--space-xs);
    position: relative;
  }

  .form-submit[data-loading] .btn-label { opacity: 0; }
  .form-submit[data-loading]::after {
    content: '';
    position: absolute;
    width: 18px; height: 18px;
    border: 2px solid oklch(99% 0 0 / 0.4);
    border-top-color: var(--paper);
    border-radius: 50%;
    animation: spin 700ms linear infinite;
  }

  @keyframes spin { to { transform: rotate(360deg); } }

  .form-status {
    font-size: var(--text-sm);
    padding: var(--space-sm) var(--space-md);
    border-radius: var(--radius-sm);
  }
  .form-status[data-state="success"] { background: var(--success-bg); color: oklch(30% 0.1 148); }
  .form-status[data-state="error"] { background: var(--error-bg); color: oklch(35% 0.15 18); }

  @media (max-width: 900px) {
    .contact-grid { grid-template-columns: 1fr; }
    .contact-info { position: static; }
  }

  @media (max-width: 560px) {
    .field-row { grid-template-columns: 1fr; }
    .contact-form-wrap { padding: var(--space-lg); }
  }
</style>

<script>
  const form = document.getElementById('booking-form') as HTMLFormElement | null;
  const statusEl = document.querySelector('[data-status]') as HTMLElement | null;
  const submitBtn = form?.querySelector('.form-submit') as HTMLButtonElement | null;

  function setFieldError(name: string, show: boolean) {
    const msg = document.querySelector(`[data-error-for="${name}"]`);
    const field = document.getElementById(name)?.closest('.field');
    if (msg) msg.toggleAttribute('hidden', !show);
    field?.classList.toggle('has-error', show);
  }

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    if (!form) return;

    const name = (document.getElementById('name') as HTMLInputElement)?.value.trim();
    const phone = (document.getElementById('phone') as HTMLInputElement)?.value.trim();

    let valid = true;
    if (!name) { setFieldError('name', true); valid = false; } else { setFieldError('name', false); }
    if (!phone) { setFieldError('phone', true); valid = false; } else { setFieldError('phone', false); }

    if (!valid) return;

    submitBtn?.setAttribute('data-loading', '');
    if (statusEl) statusEl.hidden = true;

    try {
      const formData = new FormData(form);
      const response = await fetch(form.action || '#', {
        method: 'POST',
        body: formData,
        headers: { Accept: 'application/json' },
      });

      if (response.ok) {
        if (statusEl) {
          statusEl.hidden = false;
          statusEl.dataset.state = 'success';
          statusEl.textContent = "Thanks — we've received your request and will confirm your appointment within one business day.";
        }
        form.reset();
      } else {
        throw new Error('Request failed');
      }
    } catch {
      if (statusEl) {
        statusEl.hidden = false;
        statusEl.dataset.state = 'error';
        statusEl.textContent = "We couldn't send your request. Please call the clinic directly or message us on Facebook instead.";
      }
    } finally {
      submitBtn?.removeAttribute('data-loading');
    }
  });
</script>
