---
interface Props {
  heading: string;
  body: string;
}
const { heading, body } = Astro.props;
---

<section class="cta-band">
  <div class="cta-glow" aria-hidden="true"></div>
  <div class="container cta-inner">
    <div class="cta-copy">
      <h2>{heading}</h2>
      <p class="lead">{body}</p>
    </div>
    <div class="cta-actions">
      <a href="/contact#book" class="btn btn-on-brand">Book an appointment</a>
      <a href="https://m.me/mdsDental.docrhejz" target="_blank" rel="noopener noreferrer" class="btn btn-ghost-dark">Message us on Facebook</a>
      <a href="tel:+639541439492" class="cta-phone">or call +63 954 143 9492</a>
    </div>
  </div>
</section>

<style>
  .cta-band {
    position: relative;
    background: var(--brand-600);
    color: var(--paper);
    padding-block: var(--space-3xl);
    overflow: hidden;
  }

  .cta-glow {
    position: absolute;
    inset: -20%;
    background-image: radial-gradient(circle at 15% 20%, oklch(67% 0.13 258 / 0.6), transparent 55%);
    animation: drift 16s var(--ease-out-quart) infinite alternate;
  }

  @keyframes drift {
    from { transform: translate(0, 0) scale(1); }
    to { transform: translate(4%, 3%) scale(1.06); }
  }

  @media (prefers-reduced-motion: reduce) {
    .cta-glow { animation: none; }
  }

  .cta-inner { position: relative; }

  .cta-band .btn-ghost-dark {
    border-color: oklch(97% 0.01 258 / 0.55);
  }
  .cta-band .btn-ghost-dark:hover {
    border-color: var(--paper);
    background: oklch(99% 0 0 / 0.1);
  }

  .cta-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-2xl);
    flex-wrap: wrap;
  }

  .cta-copy { max-width: 46ch; }
  .cta-copy h2 { color: var(--paper); }
  .cta-copy .lead { color: oklch(97% 0.01 258 / 0.9); margin-top: var(--space-sm); }

  .cta-actions {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: var(--space-sm);
  }

  .cta-actions .btn { width: max-content; }

  .cta-phone {
    font-size: var(--text-sm);
    color: oklch(97% 0.01 258 / 0.85);
    text-decoration: underline;
    text-underline-offset: 3px;
  }
  .cta-phone:hover { color: var(--paper); }
</style>
