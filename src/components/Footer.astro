---
import IconTooth from './IconTooth.astro';
const year = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="container footer-grid">
    <div class="footer-brand">
      <div class="footer-wordmark">
        <IconTooth class="footer-icon" />
        <span class="footer-word"><span class="wm-mds">MDS</span><span class="wm-dental">dental</span></span>
      </div>
      <p class="footer-tagline">
        <span class="rule"></span>
        <span>&amp; Aesthetics Clinic</span>
        <span class="rule"></span>
      </p>
      <p class="footer-doctor">Dra. Maria Regina Mari M. Delos Santos</p>
      <p class="footer-address">
        Brgy. Pulong Niogan, Mabini,<br />Batangas, Philippines
      </p>
    </div>

    <nav class="footer-col" aria-label="Site">
      <h2>Site</h2>
      <ul>
        <li><a href="/">Home</a></li>
        <li><a href="/services">Services</a></li>
        <li><a href="/about">About</a></li>
        <li><a href="/contact">Contact</a></li>
      </ul>
    </nav>

    <div class="footer-col">
      <h2>Services</h2>
      <ul>
        <li><a href="/services#specialist">TMJ &amp; sleep-airway care</a></li>
        <li><a href="/services#specialist">Invisalign &amp; SmarTee</a></li>
        <li><a href="/services#everyday">General dentistry</a></li>
        <li><a href="/services#everyday">Aesthetic dentistry</a></li>
      </ul>
    </div>

    <div class="footer-col">
      <h2>Reach us</h2>
      <ul>
        <li><a href="tel:+639541439492">+63 954 143 9492</a></li>
        <li><a href="https://www.facebook.com/mdsDental.docrhejz" target="_blank" rel="noopener noreferrer">Follow us on Facebook</a></li>
        <li><a href="https://m.me/mdsDental.docrhejz" target="_blank" rel="noopener noreferrer">Message us</a></li>
      </ul>
      <p class="footer-hours">Open almost every day &mdash; <a href="/contact#book">book your schedule</a></p>
    </div>
  </div>

  <div class="container footer-bottom">
    <p>&copy; {year} MDS Dental &amp; Aesthetic Clinic. All rights reserved.</p>
    <a href="/contact#book" class="footer-cta">Book an appointment &rarr;</a>
  </div>
</footer>

<style>
  .site-footer {
    background: var(--surface-dark);
    color: var(--ink-on-dark-soft);
    padding-block: var(--space-3xl) var(--space-lg);
  }

  .footer-grid {
    display: grid;
    grid-template-columns: 1.4fr 1fr 1fr 1fr;
    gap: var(--space-xl);
    padding-bottom: var(--space-2xl);
    border-bottom: 1px solid var(--border-on-dark);
  }

  .footer-wordmark {
    display: flex;
    align-items: center;
    gap: var(--space-2xs);
  }

  .footer-icon {
    width: 32px;
    height: 32px;
    color: var(--brand-300);
    flex-shrink: 0;
  }

  .footer-word {
    font-family: var(--font-body);
    font-size: 1.5rem;
    font-weight: 700;
    letter-spacing: -0.02em;
  }

  .footer-wordmark .wm-mds { color: var(--ink-on-dark); }
  .footer-wordmark .wm-dental { color: var(--brand-300); }

  .footer-tagline {
    display: flex;
    align-items: center;
    gap: var(--space-2xs);
    margin-top: var(--space-xs);
    font-size: var(--text-xs);
    letter-spacing: 0.07em;
    text-transform: uppercase;
    color: var(--ink-on-dark-soft);
  }

  .footer-tagline .rule {
    width: 14px;
    height: 1px;
    background: var(--border-on-dark);
  }

  .footer-doctor {
    margin-top: var(--space-md);
    font-size: var(--text-sm);
    color: var(--ink-on-dark);
    font-weight: 500;
  }

  .footer-address {
    margin-top: var(--space-2xs);
    font-size: var(--text-sm);
    line-height: var(--lh-snug);
  }

  .footer-col h2 {
    font-family: var(--font-body);
    font-size: var(--text-xs);
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--ink-on-dark);
    margin: 0 0 var(--space-sm);
  }

  .footer-col ul {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-xs);
  }

  .footer-col a {
    font-size: var(--text-sm);
    transition: color var(--dur-base) var(--ease-out-quart);
  }
  .footer-col a:hover { color: var(--ink-on-dark); }

  .footer-hours { margin-top: var(--space-sm); font-size: var(--text-xs); }
  .footer-hours a {
    color: var(--brand-300);
    font-weight: 600;
    text-decoration: underline;
    text-underline-offset: 2px;
  }
  .footer-hours a:hover { color: var(--ink-on-dark); }

  .footer-bottom {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-md);
    padding-top: var(--space-lg);
    font-size: var(--text-xs);
    flex-wrap: wrap;
  }

  .footer-cta {
    color: var(--brand-300);
    font-weight: 600;
    transition: color var(--dur-base) var(--ease-out-quart);
  }
  .footer-cta:hover { color: var(--ink-on-dark); }

  @media (max-width: 900px) {
    .footer-grid { grid-template-columns: 1fr 1fr; }
  }

  @media (max-width: 560px) {
    .footer-grid { grid-template-columns: 1fr; gap: var(--space-lg); }
    .footer-bottom { flex-direction: column; align-items: flex-start; }
  }
</style>
